{
  "name": "copilotcli-teams-bridge",
  "displayName": "CopilotCLI-Teams Bridge",
  "description": "Connects a Microsoft Teams personal bot to your local GitHub Copilot CLI, enabling remote workspace queries via the Teams mobile app.",
  "version": "0.0.2",
  "publisher": "nguyenchinh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThanhChinhBK/CopilotCLI-Teams-Bridge"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotcli-teams-bridge.start",
        "title": "Start Bridge",
        "category": "CopilotCLI Teams"
      },
      {
        "command": "copilotcli-teams-bridge.stop",
        "title": "Stop Bridge",
        "category": "CopilotCLI Teams"
      },
      {
        "command": "copilotcli-teams-bridge.resetTunnel",
        "title": "Reset Tunnel URL",
        "category": "CopilotCLI Teams"
      }
    ],
    "configuration": {
      "title": "CopilotCLI-Teams Bridge",
      "properties": {
        "copilotcli-teams-bridge.microsoftAppId": {
          "type": "string",
          "default": "",
          "description": "Microsoft App ID for the Azure Bot registration."
        },
        "copilotcli-teams-bridge.microsoftAppPassword": {
          "type": "string",
          "default": "",
          "description": "Microsoft App Password (client secret) for the Azure Bot registration.",
          "editPresentation": "singlelineText"
        },
        "copilotcli-teams-bridge.microsoftAppTenantId": {
          "type": "string",
          "default": "",
          "description": "Microsoft Entra tenant ID (required for Single-tenant Azure Bot)."
        },
        "copilotcli-teams-bridge.localPort": {
          "type": "number",
          "default": 3978,
          "description": "Local port for the Bot Framework webhook server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "lint": "eslint src/",
    "test": "npm run compile && node --test dist/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@microsoft/dev-tunnels-connections": "^1.0.0",
    "@microsoft/dev-tunnels-contracts": "^1.0.0",
    "@microsoft/dev-tunnels-management": "^1.0.0",
    "botbuilder": "^4.23.0",
    "botframework-connector": "^4.23.0"
  }
}
